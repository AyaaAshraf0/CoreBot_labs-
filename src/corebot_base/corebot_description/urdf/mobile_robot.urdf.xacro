  <!-- base_footprint: REP-103 canonical navigation frame (+X = physical forward).
       The CAD-exported base_link has +X pointing toward the physical BACK of the robot,
       so we rotate 180° around Z here to give nav2/amcl/ekf a correct coordinate frame. -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 3.14159265358979" />
    <parent link="base_footprint" />
    <child  link="base_link" />
  </joint>

